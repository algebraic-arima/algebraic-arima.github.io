{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: bundle install",
      "type": "shell",
      "command": "bundle",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Jekyll: serve (localhost:4000)",
      "type": "shell",
      "command": "bundle",
      "args": [
        "exec",
        "jekyll",
        "serve",
        "-l",
        "-H",
        "localhost",
        "--port",
        "4000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
